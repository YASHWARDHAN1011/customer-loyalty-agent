# Streamlit Cloud secrets template.
# On Streamlit Cloud: paste these into the app's Settings -> Secrets.
# Locally: copy to .streamlit/secrets.toml (gitignored) OR keep using .env.
# Add as many keys as you have (GEMINI_KEY_1 .. GEMINI_KEY_10); config.py
# loads whichever are present.

GEMINI_KEY_1 = "your-gemini-api-key-here"
# GEMINI_KEY_2 = "second-key-for-failover"
