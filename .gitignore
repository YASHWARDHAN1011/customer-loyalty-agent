.env
data/raw/
data/processed/
venv/
__pycache__/
*.pyc
*.csv
.ipynb_checkpoints/

# Runtime state (onboarding flag, saved chat) — never committed
.app_state/

# Cloud secrets — committed template only (secrets.toml.example)
.streamlit/secrets.toml

# Deploy artifacts ARE committed (small parquets the cloud loads).
# Only *.csv is ignored above, so data/artifacts/*.parquet is tracked by default.
!data/artifacts/
!data/artifacts/*.parquet
